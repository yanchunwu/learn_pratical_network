if [ -n "${BASH_VERSION:-}" ]; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  fi

  set -o vi

  net_header() {
    printf '\n== %s ==\n' "$1"
  }

  target_ip() {
    case "$1" in
      brain) printf '172.20.0.11\n' ;;
      left_arm|left-arm) printf '172.21.0.11\n' ;;
      right_arm|right-arm) printf '172.21.0.12\n' ;;
      router) printf '%s\n' "${ROUTER_IP:-172.21.0.254}" ;;
      *) printf '%s\n' "$1" ;;
    esac
  }

  check-self() {
    net_header "hostname"
    hostname
    net_header "interfaces"
    ip -brief addr
    net_header "routes"
    ip route
    net_header "listeners"
    ss -lntp
    net_header "dns"
    cat /etc/resolv.conf
  }

  check-router() {
    net_header "router target"
    printf 'ROUTER_IP=%s\n' "${ROUTER_IP:-unset}"
    net_header "route to router"
    if [ -n "${ROUTER_IP:-}" ]; then
      ip route get "${ROUTER_IP}"
      net_header "ping router"
      ping -c 1 "${ROUTER_IP}"
      net_header "dns served by router"
      nslookup brain "${ROUTER_IP}"
    else
      printf 'ROUTER_IP is not set in this container.\n'
      return 1
    fi
  }

  check-brain() {
    net_header "resolve brain"
    nslookup brain
    net_header "route to brain"
    ip route get 172.20.0.11
    net_header "tcp probe to brain:9000"
    printf 'hello\n' | nc -w 2 brain 9000
  }

  debug-flow() {
    local target="${1:-brain}"
    local target_addr

    target_addr="$(target_ip "${target}")"

    net_header "1. interface"
    printf 'Comment: start at the source interface. Confirm the container is on the subnet you expect.\n'
    ip -brief addr show dev eth0

    net_header "2. route"
    printf 'Comment: decide whether the target is local or remote. If remote, the next hop should be the router.\n'
    printf 'Target=%s TargetIP=%s\n' "${target}" "${target_addr}"
    ip route get "${target_addr}" 2>/dev/null || printf 'Route lookup failed for %s\n' "${target_addr}"

    net_header "3. gateway"
    printf 'Comment: if the route points to a gateway, that next hop must be reachable on the local segment.\n'
    if [ -n "${ROUTER_IP:-}" ]; then
      printf 'ROUTER_IP=%s\n' "${ROUTER_IP}"
      ping -c 1 "${ROUTER_IP}" || true
      ip neigh show dev eth0 | grep "${ROUTER_IP}" || true
    else
      printf 'ROUTER_IP is not set in this container.\n'
    fi

    net_header "4. dns"
    printf 'Comment: if you are using a name, resolve it before blaming TCP or the firewall.\n'
    cat /etc/resolv.conf
    nslookup "${target}" || true

    net_header "5. iptables"
    printf 'Comment: node-local iptables is usually not the main decision point in this lab. The key policy lives on router FORWARD.\n'
    iptables -vnL || true
    printf 'Next step on router: demo-reset ; fw ; iptables -S FORWARD\n'
  }

  sniff-brain() {
    tcpdump -ni eth0 host brain
  }

  sniff-9000() {
    tcpdump -ni eth0 tcp port 9000
  }

  l2-neighbors() {
    net_header "arp neighbors on eth0"
    ip neigh show dev eth0
    net_header "active arp scan on eth0"
    arp-scan --interface=eth0 --localnet
  }

  demo-reset() {
    net_header "demo reset"
    printf 'No router counters to reset on %s.\n' "$(hostname)"
    printf 'If you want clean firewall counters, run demo-reset on router.\n'
    net_header "interfaces"
    ip -brief addr
    net_header "routes"
    ip route
  }

  export PS1='[\u@\h \W]\$ '
  alias ll='ls -alF'
  alias la='ls -A'
  alias l='ls -CF'
  alias ifaces='ip -brief addr'
  alias routes='ip route'
  alias ports='ss -lntp'
  alias fw='iptables -vnL'
  alias dns='cat /etc/resolv.conf'
fi
